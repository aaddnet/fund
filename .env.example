# Fund - Investment Portfolio Tracker
# Copy this file to .env.local and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fund_user:fund_pass@db:5432/fund_system
POSTGRES_DB=fund_system
POSTGRES_USER=fund_user
POSTGRES_PASSWORD=fund_pass

# ── Authentication ────────────────────────────────────────────────────────
AUTH_ENABLED=true
AUTH_SECRET_KEY=change-me-to-a-random-64-char-secret

# Bootstrap admin user (created on first startup if no users exist)
AUTH_BOOTSTRAP_USERS_JSON=[{"username":"admin","password":"YourStrongPassword123","role":"admin"}]

# ── Scheduler ─────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_FX_PAIRS=HKD:USD,SGD:USD,CNY:USD,EUR:USD,GBP:USD
