# Investment Portfolio Tracker — Environment Configuration
#
# Copy this file to .env.local and fill in your values.

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/fund_system

# Authentication
AUTH_ENABLED=true
AUTH_SECRET_KEY=change-me-to-a-random-64-char-secret

# Optional: Bootstrap admin user (JSON array)
# AUTH_BOOTSTRAP_USERS_JSON=[{"username":"admin","password":"YourStrongPassword123","role":"admin"}]
